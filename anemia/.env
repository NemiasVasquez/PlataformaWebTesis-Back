# Base
CARPETA_ORIGEN=media/originales
CARPETA_PROCESADA=media/procesadas
CARPETA_MODELO=modelos_guardados/modelo_final.pt

# Filtrado de imágenes
RUTA_ENTRADA=media/originales
RUTA_SALIDA=media/procesadas/filtradas
RUTA_NO_FILTRADOS=media/procesadas/no_filtradas
RUTA_REPORTE_TXT=media/reportes/razones_rechazo.txt

# Balanceo
BALANCEO_CONTROL_ORIGEN=media/procesadas/filtradas/SIN ANEMIA
BALANCEO_ANEMIA_ORIGEN=media/procesadas/filtradas/CON ANEMIA
BALANCEO_CONTROL_SALIDA=media/procesadas/balanceadas/SIN ANEMIA
BALANCEO_ANEMIA_SALIDA=media/procesadas/balanceadas/CON ANEMIA

# Segmentación (extracción de conjuntiva)
RUTA_BALANCEADAS=media/procesadas/balanceadas
RUTA_SEGMENTADAS=media/procesadas/segmentadas
RUTA_RECORTADAS=media/procesadas/recortadas
RUTA_PNG=media/procesadas/png
RUTA_AREA=media/procesadas/area

# Resize
RUTA_PNG_RESIZE=media/procesadas/resize

# ---------------------------------------------------------
# filtradosImagenes.py - Umbrales y Métricas
# ---------------------------------------------------------

# Varianza mínima del Laplaciano para nitidez global
NITIDEZ_UMBRAL_LAP=4
# Energía mínima de gradientes Sobel para foco óptico
NITIDEZ_UMBRAL_TENENGRAD=4
# Ratio de alta frecuencia FFT para detectar bokeh
NITIDEZ_UMBRAL_HF_RATIO=0.01
# Varianza mínima Modified Laplacian en zona central
NITIDEZ_UMBRAL_VMLAP_CENTRO=4
# Varianza mínima Modified Laplacian sobre la conjuntiva
NITIDEZ_UMBRAL_VMLAP_MASCARA=80
# Radio del espectro central a ignorar en FFT (bajas frecuencias)
NITIDEZ_FFT_RADIO_FRACCION=0.05
# Margen para recorte de ROI central (30%)
NITIDEZ_ROI_MARGEN=0.15
# Mínimo de píxeles en máscara para validar nitidez local
NITIDEZ_MIN_PIXELES_MASCARA=200

# Fracción mínima de área que debe ocupar el iris (0.5%)
OJO_MIN_AREA_FRACCION=0.005

# Porcentaje mínimo de blanco (esclerótica) detectado
ESCLEROTICA_UMBRAL_AREA=0.01

# Lado mínimo (ancho/alto) de la imagen JPEG
TAMANO_MIN_PX=200

# Porcentaje mínimo del área de la imagen para la conjuntiva 
CONJUNTIVA_MIN_AREA_PCT=0.015
# Relación de aspecto mínima (horizontal) para la conjuntiva
CONJUNTIVA_MIN_ASPECT_RATIO=1.0
# Fracción mínima del ancho de la imagen para la conjuntiva (20%)
CONJUNTIVA_MIN_ANCHO_FRACCION=0.10
# Porcentaje máximo de píxeles oscuros permitidos dentro de la conjuntiva (pestañas)
CONJUNTIVA_MAX_PESTANAS_PCT=0.02

# ---------------------------------------------------------
# extraccionConjuntiva.py - Parámetros de Algoritmo
# ---------------------------------------------------------

# Valor clip para ecualización adaptativa de contraste CLAHE
SEG_CLAHE_CLIP=3.0
# Tamaño de la cuadrícula para el filtro CLAHE
SEG_CLAHE_GRID=8

# Factor de resolución inversa del acumulador (Hough Circles)
IRIS_HOUGH_DP=1
# Distancia mínima entre centros de círculos detectados
IRIS_HOUGH_DIST=50
# Umbral superior para detector de bordes Canny
IRIS_HOUGH_P1=100
# Umbral para detección de centros (acumulador)
IRIS_HOUGH_P2=30
# Radio mínimo del iris a buscar
IRIS_HOUGH_MIN_R=30
# Radio máximo del iris a buscar
IRIS_HOUGH_MAX_R=150

# Umbral de gris para detectar zonas oscuras (iris/pupila)
IRIS_DARK_THRES=55
# Área mínima del contorno oscuro para ser iris válido
IRIS_MIN_AREA=400

# Margen superior (Y) para iniciar ventana de búsqueda (ROI)
SEG_SEARCH_Y_START_FACTOR=0.5

# Umbral de luminosidad LAB (L) para detectar pelo (oscuro)
SEG_PELO_L_THRES=75
# Umbral de luminosidad LAB (L) para detectar blanco de ojo
SEG_BLANCO_L_THRES=190
# Umbral de canal A (rojo) para detectar conjuntiva
SEG_ROJO_A_THRES=135

# Factor de radio para pared superior (evitar párpado/esclera)
SEG_Y_WALL_FACTOR=0.8

# Área mínima de contorno para ser considerado conjuntiva
SEG_MIN_AREA=500
# Relación aspecto mínima pre-filtrado
SEG_MIN_ASPECT_PRE=1.2
# Relación aspecto mínima cavernícola para puntaje
SEG_MIN_ASPECT_CAVE=1.4
# Factor de posición vertical objetivo para el puntaje (Y)
SEG_Y_TARGET_FACTOR=1.25
# Índice de solidez (convexidad) objetivo para la forma
SEG_SOLIDITY_TARGET=0.70

# Offset de canal rojo para refinamiento local de máscara
SEG_REFINE_A_OFFSET=5

# Paso en X (píxeles) para cerrar huecos en la medialuna
SEG_CLOSE_STEP=20
